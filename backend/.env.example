# Copy to .env (never commit .env)
APP_ENV=development
DATABASE_URL=postgresql+asyncpg://seedjournal:seedjournal_dev@127.0.0.1:5432/seedjournal
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
APPLE_CLIENT_ID=com.seedjournal.app

# stub = local dev without API keys
# openai = production-quality guide + embeddings (text-embedding-3-small = 1536 dims)
LLM_PROVIDER=stub
OPENAI_API_KEY=
LLM_MODEL_FAST=gpt-4o-mini
LLM_MODEL_GUIDE=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
LLM_TIMEOUT_SEC=30

# Production: comma-separated origins (not *)
CORS_ORIGINS=